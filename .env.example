# --- Database ---
# When running locally (without Docker), point to a local Postgres
# When using docker-compose, override with host=db (already set inside compose)
DATABASE_URL=postgresql://broker:broker@localhost:5432/broker?schema=public

# --- API ---
API_PORT=3001
# Origin allowed by NestJS CORS (the Next.js dev server / web container)
WEB_ORIGIN=http://localhost:3000

# --- Web ---
WEB_PORT=3000
# Internal URL the Next.js server uses to reach the API.
# Local dev: http://localhost:3001/api
# Docker:    http://api:3001/api
API_URL_INTERNAL=http://localhost:3001/api
